    },
    "This device doesn't support Face Tracking.\nPlease use an iPad with TrueDepth camera.": {
      "comment": "SessionTrackingView unsupported device message",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このデバイスは顔追跡をサポートしていません。\nTrueDepthカメラを搭載したデバイスをご使用ください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 기기는 얼굴 추적을 지원하지 않아요.\nTrueDepth 카메라가 있는 기기를 사용해 주세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此设备不支持面部追踪。\n请使用配备TrueDepth相机的设备。"
          }
        }
      }
    },
    "This week": {
