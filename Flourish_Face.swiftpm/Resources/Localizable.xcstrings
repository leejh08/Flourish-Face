          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "再试一次"
          }
        }
      }
    },
    "Tulip": {
      "comment": "FlowerType.tulip name",
      "localizations": {
        "ja": {
          "stringUnit": {
