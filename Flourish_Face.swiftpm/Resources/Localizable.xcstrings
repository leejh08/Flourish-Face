{
  "sourceLanguage": "en",
  "strings": {
    "%@ of %d seconds": {
      "comment": "SessionTrackingView VoiceOver value for hold timer",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%2$d秒中%1$@秒"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%2$d초 중 %1$@초"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%2$d秒中%1$@秒"
          }
        }
      }
    },
    "%@ side affected": {
      "comment": "SideButton VoiceOver label, %@ is Left/Right (localized)",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@側がマヒ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 쪽 마비"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@侧面瘫痪"
          }
        }
      }
    },
    "%lld Sets": {
      "comment": "SessionIntroView: number of sets display",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld セット"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 세트"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 组"
          }
        }
      }
    },
    "%lld flowers collected": {
      "comment": "CollectionView: subtitle showing total flowers",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "花 %lld 本収集"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "꽃 %lld송이를 모았어요"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已收集 %lld 朵花"
          }
        }
      }
    },
    "%lld of 7 days completed": {
      "comment": "LogStreakCard: weekly completion subtitle",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今週の達成: %lld日"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "7일 중 %lld일 완료"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "7天中完成了 %lld 天"
          }
        }
      }
    },
    "%lld sessions completed": {
      "comment": "LogView: subtitle showing total sessions",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "累計完了: %lld回"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld회 운동 완료"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "累计完成 %lld 次"
          }
        }
      }
    },
    "3 simple exercises\nfor beginners": {
      "comment": "Difficulty.basic description",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "初心者向けの\n3つの簡単なエクササイズ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "초보자를 위한\n3가지 간단한 운동"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "适合初学者的\n3个简单练习"
          }
        }
      }
    },
    "5 exercises\nfor a full workout": {
      "comment": "Difficulty.advanced description",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フルワークアウトのための\n5つのエクササイズ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "전체 운동을 위한\n5가지 운동"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "完整锻炼的\n5个练习"
          }
        }
      }
    },
    "A breeze wraps around the garden\nFreely relax\nyour expression": {
      "comment": "Chapter.breeze story",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "そよ風が庭を包む\n自由に\n表情をリラックスさせましょう"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "바람이 정원을 감싸요\n자유롭게\n표정을 이완하세요"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "微风环绕花园\n自由地\n放松你的表情"
          }
        }
      }
    },
    "A tiny seed is waking up\nBreathe life into it\nwith gentle movements": {
      "comment": "Chapter.seed story",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "小さな種が目覚めている\n優しい動きで\n命を吹き込んでください"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "작은 씨앗이 깨어나고 있어요\n부드러운 움직임으로\n생명을 불어넣어 주세요"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一粒小种子正在苏醒\n用轻柔的动作\n为它注入生命"
          }
        }
      }
    },
    "A warmer smile awaits.": {
      "comment": "HomeView daily quote (Sunday)",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "より温かい笑顔が待っています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "더 따뜻한 미소가 기다리고 있어요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "更温暖的微笑在等待着你。"
          }
        }
      }
    },
    "Advanced": {
      "comment": "Difficulty.advanced display name",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "上級"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "심화"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "高级"
          }
        }
      }
    },
    "Affected Side": {
      "comment": "LogSettingsCard setting row title",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "麻痺側"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "마비된 쪽"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "患侧设置"
          }
        }
      }
    },
    "All Done Today": {
      "comment": "HomeView completion status label",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今日の運動完了"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오늘 운동 완료"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "今日完成"
          }
        }
      }
    },
    "Almost There": {
      "comment": "HomeView start button label (4th exercise)",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "もう少し"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "거의 다 왔어요"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "快到了"
          }
        }
      }
    },
    "Almost there!": {
      "comment": "SessionTrackingView feedback label",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "もう少しです！"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "거의 다 왔어요!"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "快到了！"
          }
        }
      }
    },
    "Amazing Effort!": {
      "comment": "RestView bonus completion title variant",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "素晴らしい努力！"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "대단한 노력이에요!"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "太努力了！"
          }
        }
      }
    },
    "Awaken the Seed": {
      "comment": "Chapter.seed title",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "種を目覚めさせる"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "씨앗을 깨우다"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "唤醒种子"
          }
        }
      }
    },
    "Basic": {
      "comment": "Difficulty.basic display name",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "基礎"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기초"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "基础"
          }
        }
      }
    },
    "Believe in your bloom.": {
      "comment": "HomeView daily quote (default)",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなたの開花を信じてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "꾸준히, 반드시 피어날 거예요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "相信你会绽放。"
          }
        }
      }
    },
    "Bloom the Flower": {
      "comment": "Chapter.bloom title",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "花を咲かせる"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "꽃을 피우다"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "让花绽放"
          }
        }
      }
    },
    "Brow": {
      "comment": "FaceExercise.browRaise short name",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "眉"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "눈썹"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "眉毛"
          }
        }
      }
    },
    "Build the Momentum": {
      "comment": "HomeView start button label (2nd exercise, advanced)",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "勢いをつけましょう"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "탄력을 붙여보세요"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "积累动力"
          }
        }
      }
    },
    "But healing begins\nwith one small movement.": {
      "comment": "IntroView phase 2 text",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "でも回復は\n小さな一つの動きから始まります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "하지만 치유는\n작은 움직임 하나에서 시작돼요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "但康复\n从一个小小的动作开始。"
          }
        }
      }
    },
    "Camera Access Required": {
      "comment": "HomeView alert title",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カメラのアクセスが必要"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "카메라 접근 권한 필요"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "需要相机权限"
          }
        }
      }
    },
    "Cancel": {
      "comment": "Generic cancel button",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キャンセル"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "취소"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "取消"
          }
        }
      }
    },
    "Cherry Blossom": {
      "comment": "FlowerType.cherry name",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "桜"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "벚꽃"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "樱花"
          }
        }
      }
    },
    "Choose one to add to your collection": {
      "comment": "FlowerPickerView subtitle",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コレクションに追加する花を選んでください"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "컬렉션에 추가할 꽃을 선택하세요"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择一朵加入你的收藏"
          }
        }
      }
    },
    "Choose your flower\nwhen you return home": {
      "comment": "RestView day complete subtitle",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ホームに戻ったら\n花を選んでください"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "홈으로 돌아가면\n꽃을 선택하세요"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "回到主页时\n选择你的花"
          }
        }
      }
    },
    "Choose your level": {
      "comment": "DifficultySelectionPage title",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "レベルを選択してください"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "난이도를 선택하세요"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择你的级别"
          }
        }
      }
    },
    "Close both eyes tightly": {
      "comment": "FaceExercise.eyeClosure guide",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "両目をしっかり閉じましょう"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "두 눈을 꼭 감아보세요"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用力闭上双眼"
          }
        }
      }
    },
    "Close session": {
      "comment": "SessionTrackingView accessibility label for close button",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セッションを閉じる"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "세션 닫기"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭训练"
          }
        }
      }
    },
    "Collect": {
      "comment": "FlowerPickerView confirm button",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "収集する"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "수집하기"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "收集"
          }
        }
      }
    },
    "Collection": {
      "comment": "Tab bar label",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コレクション"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "수집"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "收藏"
          }
        }
      }
    },
    "Complete Your Day": {
      "comment": "HomeView start button label (last exercise, basic)",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今日を締めくくりましょう"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오늘을 마무리하세요"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "完成今天的训练"
          }
        }
      }
    },
    "Complete all exercises\nto collect a flower.": {
      "comment": "OnboardingView page 2 subtitle",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべてのエクササイズを完了して\n花を集めましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모든 운동을 완료하면\n꽃을 받을 수 있어요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "完成所有练习\n即可获得一朵花。"
          }
        }
      }
    },
    "Consistency is the key.\nYou're doing amazing!": {
      "comment": "HomeView completion quote (Monday)",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "継続が鍵です。\n素晴らしいですよ！"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "꾸준함이 핵심이에요.\n정말 잘하고 있어요!"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "坚持是关键。\n你做得太棒了！"
          }
        }
      }
    },
    "Daily exercises\nto support your recovery.": {
      "comment": "OnboardingView page 1 subtitle",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "回復をサポートする\n毎日のエクササイズ。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "회복을 돕는\n매일의 운동."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每日练习\n助力你的康复。"
          }
        }
      }
    },
    "Daily workout intensity": {
      "comment": "LogSettingsCard difficulty row subtitle",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1日の運動強度"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "일일 운동 강도"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每日训练强度"
          }
        }
      }
    },
    "Daisy": {
      "comment": "FlowerType.daisy name",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デイジー"
          }
        },
        "ko": {
