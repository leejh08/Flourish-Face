    "Your sessions, flowers, and settings will be permanently deleted. This cannot be undone.": {
      "comment": "LogSettingsCard reset confirmation alert message",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セッション、花、設定が完全に削除されます。この操作は元に戻せません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "세션, 꽃, 설정이 영구적으로 삭제됩니다. 되돌릴 수 없어요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的训练、花朵和设置将被永久删除。此操作无法撤销。"
          }
