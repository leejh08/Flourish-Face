          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "郁金香"
          }
        }
      }
    },
    "Wake Up Your Smile": {
      "comment": "HomeView start button label (1st exercise, basic)",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "笑顔を目覚めさせましょう"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "미소를 깨워보세요"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "唤醒你的微笑"
          }
        }
      }
    },
    "Watch your smile\ngrow stronger.": {
      "comment": "OnboardingView page 3 subtitle",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "笑顔が\n強くなっていくのを見守りましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "미소가 점점\n강해지는 걸 지켜보세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "看着你的微笑\n变得更有力。"
          }
        }
      }
    },
    "We couldn't capture your smile.\nTry again or skip to use default settings.": {
      "comment": "SessionCalibrateView failed state message",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "笑顔を検出できませんでした。\nもう一度試すか、スキップしてデフォルト設定を使用してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "미소를 감지하지 못했어요.\n다시 시도하거나 건너뛰어 기본 설정을 사용하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未能捕捉到你的微笑。\n请再试一次或跳过以使用默认设置。"
          }
        }
      }
    },
    "We'll mirror your healthy side\nas a guide during exercises.": {
      "comment": "AffectedSideSelectionPage subtitle",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エクササイズ中は健康な側を\n鏡のようにガイドとして表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "운동 중 건강한 쪽을\n거울처럼 가이드로 보여드릴게요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我们将在练习中\n镜像你健康的一侧作为引导。"
          }
        }
      }
    },
    "When you press the button below,\nsmile as wide as you can for 5 seconds.\nWe'll use it to set your personal target.": {
      "comment": "SessionCalibrateView ready state instruction",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "下のボタンを押すと、\n5秒間できる限り大きく笑ってください。\n個人目標の設定に使用します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아래 버튼을 누르면\n5초 동안 최대한 크게 웃어주세요.\n개인 목표를 설정하는 데 사용할게요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按下面的按钮后，\n尽可能地大笑5秒钟。\n我们将用它来设定你的个人目标。"
          }
        }
      }
    },
    "When your own smile\nfeels out of reach.": {
      "comment": "IntroView phase 1 text",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自分の笑顔が\n遠く感じるとき。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "자신의 미소가\n멀게만 느껴질 때."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当自己的微笑\n感觉遥不可及时。"
          }
        }
      }
    },
    "Which exercise would you like to practice?": {
      "comment": "ExercisePickerSheet subtitle",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "どのエクササイズを練習しますか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "어떤 운동을 연습하고 싶으세요?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你想练习哪个动作？"
          }
        }
      }
    },
    "Which side is affected?": {
      "comment": "AffectedSideSelectionPage title",
      "localizations": {
        "ja": {
