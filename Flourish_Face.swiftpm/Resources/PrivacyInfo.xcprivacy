<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App does not track users across apps or websites -->
    <key>NSPrivacyTracking</key>
    <false/>

    <!-- No tracking domains -->
    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <!--
        No data is collected, transmitted, or linked to user identity.
        Camera frames are processed on-device in real time and immediately discarded.
        All persistent data (sessions, flowers, settings) stays on the user's device only.
    -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array/>

    <!-- UserDefaults is used to store app preferences and daily exercise progress -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- CA92.1: Access info from the same app that previously wrote the data -->
                <string>CA92.1</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
